{
    "name": "bandagroep/peepl-php",
    "description": "PHP client library for the Peepl CRM API",
    "type": "library",
    "license": "MIT",
    "keywords": ["peepl", "crm", "api", "client", "vereniging"],
    "homepage": "https://github.com/bandagroep/peepl-php",
    "authors": [
        {
            "name": "Bandagroep",
            "email": "dev@bandagroep.nl"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Peepl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Peepl\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
